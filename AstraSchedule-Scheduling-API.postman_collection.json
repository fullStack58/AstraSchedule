              "protocol": "http",
              "host": ["localhost"],
              "port": "3001",
              "path": ["api", "scheduling", "validate"]
            },
            "description": "Valida estructura de datos sin procesar"
          },
          "response": []
        },
        {
          "name": "3. Schedule Single Group",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"grupo\": {\n    \"id\": 1,\n    \"nombre\": \"IS-101 - Grupo A\",\n    \"materia_codigo\": \"IS-101\",\n    \"jornada\": \"Diurna\",\n    \"modalidad\": \"presencial\",\n    \"sede_codigo\": \"NORTE\",\n    \"cupo_max\": 30,\n    \"cupo_estimado\": 10,\n    \"tipo_aula_requerida\": \"presencial\",\n    \"prioridad\": 1\n  },\n  \"docentes\": [\n    {\n      \"id\": 1,\n      \"nombre\": \"Juan García\",\n      \"disponibilidad\": \"Ambas\",\n      \"carga_max_horas\": 20,\n      \"horas_asignadas\": 0\n    }\n  ],\n  \"salones\": [\n    {\n      \"id\": 1,\n      \"codigo\": \"N-001\",\n      \"tipo\": \"presencial\",\n      \"capacidad\": 30,\n      \"sede_codigo\": \"NORTE\"\n    }\n  ],\n  \"franjas\": [\n    {\n      \"id\": 1,\n      \"dia\": \"Lunes\",\n      \"jornada\": \"Diurna\",\n      \"hora_inicio\": \"07:00\",\n      \"hora_fin\": \"10:00\"\n    }\n  ]\n}"
